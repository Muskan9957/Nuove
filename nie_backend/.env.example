# Nuove Intelligence Engine (NIE) - Environment Variables
# Copy this file to .env and adjust as necessary

# Database Configuration
DATABASE_URL=sqlite:///./nie.db
# Example Postgres:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nie_db

# SSL Config (Optional)
HIGH_SIMILARITY_THRESHOLD=0.80
LOW_SIMILARITY_THRESHOLD=0.40
